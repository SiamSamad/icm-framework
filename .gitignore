node_modules/
automation/playwright/.auth/
playwright-report/
test-results/
blob-report/
.cache/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

playwright/**/test-results/
playwright/**/playwright-report/
playwright/**/auth/*session*
